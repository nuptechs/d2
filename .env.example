# ============================================================
# Debug Probe — Environment Variables
# Copy to .env and fill in values
# ============================================================

# Server
PORT=7070
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# Database (optional — defaults to in-memory if not set)
POSTGRES_DB=debug_probe
POSTGRES_USER=probe
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgres://probe:change-me-in-production@localhost:5432/debug_probe

# Authentication (set at least one to enable auth)
PROBE_API_KEYS=
PROBE_JWT_SECRET=
PROBE_AUTH_DISABLED=1

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Storage (if not using PostgreSQL)
STORAGE_TYPE=memory
STORAGE_PATH=.probe-data
